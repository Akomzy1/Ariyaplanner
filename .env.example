# AriyaPlanner — environment variables
# Copy to `.env.local` and fill in. Never commit real secrets.
# Keys are named here in P1; each is wired up in the prompt that needs it.

# ── App ───────────────────────────────────────────────────────────────────────
# Public base URL of the deployment (used for metadataBase, absolute links).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Supabase (P2/P3) ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Server-only. Bypasses RLS — never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=""

# ── Claude / Anthropic API (P8/P13/P15/P19) ───────────────────────────────────
ANTHROPIC_API_KEY=""
# Sonnet-class for the Architect conversation + drafting.
ANTHROPIC_MODEL_SONNET="claude-sonnet-5"
# Haiku-class for classification / extraction / nudge copy.
ANTHROPIC_MODEL_HAIKU="claude-haiku-4-5-20251001"

# ── Paystack (P16; contributions/escrow in Phase 2) ───────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=""
# Server-only. Also used to verify webhook signatures (HMAC SHA512).
PAYSTACK_SECRET_KEY=""

# ── WhatsApp Business Cloud API (P17/P18/P19) ─────────────────────────────────
WHATSAPP_API_VERSION="v21.0"
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_ACCESS_TOKEN=""
# App secret — verifies inbound webhook signatures (X-Hub-Signature-256).
WHATSAPP_APP_SECRET=""
# Arbitrary token you choose; echoed back during Meta webhook verification.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""

# ── PostHog analytics (P26) ───────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# ── Resend (email fallback only) (P18/P27) ────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="AriyaPlanner <hello@ariyaplanner.com>"

# ── Cron / background jobs (P13 drift recompute, P17 outbox worker) ────────────
# Shared secret guarding scheduled route handlers.
CRON_SECRET=""
